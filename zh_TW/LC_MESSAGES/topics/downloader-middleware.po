#: ../../../topics/downloader-middleware.rst:622
msgid "HTTPCACHE_DBM_MODULE"
msgstr "HTTPCACHE_DBM_MODULE"

#: ../../../topics/downloader-middleware.rst:624
msgid "Default: ``'dbm'``"
msgstr "預設值：``dbm``"

#: ../../../topics/downloader-middleware.rst:626
