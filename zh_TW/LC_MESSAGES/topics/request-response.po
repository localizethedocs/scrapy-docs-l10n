#: ../../../topics/request-response.rst:540
msgid "Returns the body of the response as unicode. This is equivalent to::"
msgstr ""

#: ../../../topics/request-response.rst:542
msgid "response.body.decode(response.encoding)"
msgstr ""

#: ../../../topics/request-response.rst:544
msgid "But **not** equivalent to::"
msgstr ""

#: ../../../topics/request-response.rst:546
msgid "unicode(response.body)"
msgstr ""

#: ../../../topics/request-response.rst:548
msgid ""
"Since, in the latter case, you would be using you system default encoding "
"(typically `ascii`) to convert the body to unicode, instead of the response "
"encoding."
msgstr ""

#: ../../../topics/request-response.rst:554
msgid "A shortcut to ``TextResponse.selector.xpath(query)``::"
msgstr ""

#: ../../../topics/request-response.rst:556
msgid "response.xpath('//p')"
msgstr ""

#: ../../../topics/request-response.rst:560
msgid "A shortcut to ``TextResponse.selector.css(query)``::"
msgstr ""

#: ../../../topics/request-response.rst:562
msgid "response.css('p')"
msgstr ""

