#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:1
msgid "Default scheduler."
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:3
msgid ""
"Requests are stored into priority queues (:setting:"
"`SCHEDULER_PRIORITY_QUEUE`) that sort requests by :attr:`~scrapy.http."
"Request.priority`."
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:7
msgid ""
"By default, a single, memory-based priority queue is used for all requests. "
"When using :setting:`JOBDIR`, a disk-based priority queue is also created, "
"and only unserializable requests are stored in the memory-based priority "
"queue. For a given priority value, requests in memory take precedence over "
"requests in disk."
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:13
msgid ""
"Each priority queue stores requests in separate internal queues, one per "
"priority value. The memory priority queue uses :setting:"
"`SCHEDULER_MEMORY_QUEUE` queues, while the disk priority queue uses :setting:"
"`SCHEDULER_DISK_QUEUE` queues. The internal queues determine :ref:`request "
"order <request-order>` when requests have the same priority. :ref:`Start "
"requests <start-requests>` are stored into separate internal queues by "
"default, and :ref:`ordered differently <start-request-order>`."
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:21
msgid ""
"Duplicate requests are filtered out with an instance of :setting:"
"`DUPEFILTER_CLASS`."
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:27
msgid "Request order"
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:29
msgid ""
"With default settings, pending requests are stored in a LIFO_ queue (:ref:"
"`except for start requests <start-request-order>`). As a result, crawling "
"happens in `DFO order`_, which is usually the most convenient crawl order. "
"However, you can enforce :ref:`BFO <bfo>` or :ref:`a custom order <custom-"
"request-order>` (:ref:`except for the first few requests <concurrency-v-"
"order>`)."
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:42
msgid "Start request order"
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:44
msgid ""
":ref:`Start requests <start-requests>` are sent in the order they are "
"yielded from :meth:`~scrapy.Spider.start`, and given the same :attr:`~scrapy."
"http.Request.priority`, other requests take precedence over start requests."
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:49
msgid ""
"You can set :setting:`SCHEDULER_START_MEMORY_QUEUE` and :setting:"
"`SCHEDULER_START_DISK_QUEUE` to ``None`` to handle start requests the same "
"as other requests when it comes to order and priority."
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:57
msgid "Crawling in BFO order"
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:59
msgid ""
"If you do want to crawl in `BFO order`_, you can do it by setting the "
"following :ref:`settings <topics-settings>`:"
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:62
msgid ":setting:`DEPTH_PRIORITY` = ``1``"
msgstr ":setting:`DEPTH_PRIORITY` = ``1``"

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:64
msgid ""
":setting:`SCHEDULER_DISK_QUEUE` = ``\"scrapy.squeues.PickleFifoDiskQueue\"``"
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:65
msgid ""
":setting:`SCHEDULER_MEMORY_QUEUE` = ``\"scrapy.squeues.FifoMemoryQueue\"``"
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:73
msgid "Crawling in a custom order"
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:75
msgid ""
"You can manually set :attr:`~scrapy.http.Request.priority` on requests to "
"force a specific request order."
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:82
msgid "Concurrency affects order"
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:84
msgid ""
"While pending requests are below the configured values of :setting:"
"`CONCURRENT_REQUESTS`, :setting:`CONCURRENT_REQUESTS_PER_DOMAIN` or :setting:"
"`CONCURRENT_REQUESTS_PER_IP`, those requests are sent concurrently."
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.Scheduler:89
msgid ""
"As a result, the first few requests of a crawl may not follow the desired "
"order. Lowering those settings to ``1`` enforces the desired order except "
"for the very first request, but it significantly slows down the crawl as a "
"whole."
msgstr ""

