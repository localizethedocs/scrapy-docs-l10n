msgid "``\"stats\"`` shows the current value of some stats."
msgstr "``\"stats\"`` 显示了某些统计数据的当前值。"

#: ../../../topics/extensions.rst:402
msgid "The :setting:`PERIODIC_LOG_STATS` setting determines the target stats."
msgstr ""

#: ../../../topics/extensions.rst:404
msgid "``\"time\"`` shows detailed timing data."
msgstr "``\"time\"`` 会显示详细的计时数据。"

#: ../../../topics/extensions.rst:406
msgid ""
"The :setting:`PERIODIC_LOG_TIMING_ENABLED` setting determines whether or not "
"to show this section."
msgstr ""

#: ../../../topics/extensions.rst:409
msgid ""
"This extension logs data at the start, then on a fixed time interval "
"configurable through the :setting:`LOGSTATS_INTERVAL` setting, and finally "
"right before the crawl ends."
