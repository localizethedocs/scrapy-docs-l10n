#: ../../../topics/extensions.rst:414
msgid "Example extension configuration:"
msgstr "示例扩展配置："

#: ../../../topics/extensions.rst:416
msgid ""
"custom_settings = {\n"
"    \"LOG_LEVEL\": \"INFO\",\n"
"    \"PERIODIC_LOG_STATS\": {\n"
"        \"include\": [\"downloader/\", \"scheduler/\", \"log_count/\", "
"\"item_scraped_count/\"],\n"
"    },\n"
"    \"PERIODIC_LOG_DELTA\": {\"include\": [\"downloader/\"]},\n"
"    \"PERIODIC_LOG_TIMING_ENABLED\": True,\n"
"    \"EXTENSIONS\": {\n"
"        \"scrapy.extensions.periodic_log.PeriodicLog\": 0,\n"
"    },\n"
"}"
msgstr ""

#: ../../../topics/extensions.rst:433
msgid "PERIODIC_LOG_DELTA"
msgstr "PERIODIIC_LOG_DELTA"

#: ../../../topics/extensions.rst:435 ../../../topics/extensions.rst:446
msgid "Default: ``None``"
msgstr "默认值： ``None``"

#: ../../../topics/extensions.rst:437
msgid ""
"``\"PERIODIC_LOG_DELTA\": True`` - show deltas for all ``int`` and ``float`` "
"stat values."
msgstr ""
"``\"PERIODIIC_LOG_DELTA\": True`` - 显示所有的 ``int`` 和 ``float`` 统计数"
"值。"

#: ../../../topics/extensions.rst:438
msgid ""
"``\"PERIODIC_LOG_DELTA\": {\"include\": [\"downloader/\", \"scheduler/\"]}`` "
"- show deltas for stats with names containing any configured substring."
msgstr ""
"``\"PERIODIIC_LOG_DELTA\": {\"include\": [\"downloader\", \"scheduler/\"]}`` "
"- 显示含有任何已配置子字符串的数据的三角洲。"

#: ../../../topics/extensions.rst:439
msgid ""
"``\"PERIODIC_LOG_DELTA\": {\"exclude\": [\"downloader/\"]}`` - show deltas "
"for all stats with names not containing any configured substring."
msgstr ""
"``\"PERIODIIC_LOG_DELTA\": {\"exclude\": [\"downloader/\"]}`` - 为所有不含任"
"何配置的子字符串的状态显示三角洲。"

#: ../../../topics/extensions.rst:444
msgid "PERIODIC_LOG_STATS"
msgstr "PLAYLIST_DESCRIPTION"

#: ../../../topics/extensions.rst:448
msgid "``\"PERIODIC_LOG_STATS\": True`` - show the current value of all stats."
msgstr "``\"PERIODIIC_LOG_STATS\": True`` - 显示所有统计状态的当前值。"

#: ../../../topics/extensions.rst:449
msgid ""
"``\"PERIODIC_LOG_STATS\": {\"include\": [\"downloader/\", \"scheduler/\"]}`` "
"- show current values for stats with names containing any configured "
"substring."
msgstr ""
"``\"PERIODIIC_LOG_STATS\": {\"include\": [\"downloader/\", \"scheduler/\"]}"
"`` - 显示包含任何配置的子字符串的当前统计信息。"

#: ../../../topics/extensions.rst:450
msgid ""
"``\"PERIODIC_LOG_STATS\": {\"exclude\": [\"downloader/\"]}`` - show current "
"values for all stats with names not containing any configured substring."
msgstr ""
"``\"PERIODIIC_LOG_STATS\": {\"exclude \": [\"downloader/\"]}`` - 显示所有不含"
"任何已配置子字符串的统计数据的当前值。"

#: ../../../topics/extensions.rst:456
msgid "PERIODIC_LOG_TIMING_ENABLED"
msgstr "PERIODIIC_LOG_TIMING_DESCRIPTION"

#: ../../../topics/extensions.rst:458
msgid "Default: ``False``"
msgstr "默认值： ``False``"

#: ../../../topics/extensions.rst:460
msgid ""
"``True`` enables logging of timing data (i.e. the ``\"time\"`` section)."
msgstr "``True`` 能够记录计时数据(例如``\"time\"`` 部分)。"

#: ../../../topics/extensions.rst:464
msgid "Debugging extensions"
msgstr "调试扩展"

#: ../../../topics/extensions.rst:467
msgid "Stack trace dump extension"
msgstr "堆栈跟踪转储扩展"

#: ../../../topics/extensions.rst:471
msgid ""
"Dumps information about the running process when a `SIGQUIT`_ or `SIGUSR2`_ "
"signal is received. The information dumped is the following:"
msgstr ""
"当收到`SIGQUIT`_ 或 `SIGUSR2_ 信号时有关运行过程的信息。丢失的信息如下："

#: ../../../topics/extensions.rst:474
msgid "engine status (using ``scrapy.utils.engine.get_engine_status()``)"
msgstr "引擎状态 (使用 ``scrapy.utils.engine.get_engine_status()`` )"

#: ../../../topics/extensions.rst:475
msgid "live references (see :ref:`topics-leaks-trackrefs`)"
msgstr ""

#: ../../../topics/extensions.rst:476
msgid "stack trace of all threads"
msgstr "所有线程的堆栈跟踪"

#: ../../../topics/extensions.rst:478
msgid ""
"After the stack trace and engine status is dumped, the Scrapy process "
"continues running normally."
msgstr "堆栈跟踪和引擎状态被倾弃后，废料处理继续正常运行。"

#: ../../../topics/extensions.rst:481
msgid ""
"This extension only works on POSIX-compliant platforms (i.e. not Windows), "
"because the `SIGQUIT`_ and `SIGUSR2`_ signals are not available on Windows."
msgstr ""
"这个扩展仅适用于与 POSIX兼容的平台(即不适用于Windows)，因为“SIGQUIT`_ 和 "
"“SIGUSR2_ 信号”在Windows上不可用。"

#: ../../../topics/extensions.rst:484
msgid "There are at least two ways to send Scrapy the `SIGQUIT`_ signal:"
msgstr "至少有两种方式发送废件`SIGQUIT`_ 信号："

#: ../../../topics/extensions.rst:486
msgid "By pressing Ctrl-\\ while a Scrapy process is running (Linux only?)"
msgstr "当Scrapy process 正在运行时按 Ctrl \\ (仅限Linux？)"

#: ../../../topics/extensions.rst:487
msgid ""
"By running this command (assuming ``<pid>`` is the process id of the Scrapy "
"process)::"
msgstr "通过运行此命令(假定``<pid>`` 是Scrapy进程的进程ID)::"

#: ../../../topics/extensions.rst:490
msgid "kill -QUIT <pid>"
msgstr "击杀-QUIT <pid>"

#: ../../../topics/extensions.rst:496
msgid "Debugger extension"
msgstr "调试器扩展"

