#: ../../../topics/request-response.rst:261
msgid ""
"Use :doc:`form2request <form2request:index>` to build request data from an "
"HTML ``<form>`` element and convert it to a :class:`~scrapy.Request`."
msgstr ""

#: ../../../topics/request-response.rst:264
msgid "Install it with pip:"
msgstr ""

#: ../../../topics/request-response.rst:266
msgid "pip install form2request"
msgstr ""

#: ../../../topics/request-response.rst:270
msgid ""
"Select the desired form with CSS or XPath, then build and convert request "
"data:"
msgstr ""

#: ../../../topics/request-response.rst:273
msgid ""
"from form2request import form2request\n"
"\n"
"\n"
"def parse(self, response):\n"
"    form = response.css(\"form#search\")\n"
"    request_data = form2request(form, data={\"q\": \"scrapy\"})\n"
"    yield request_data.to_scrapy(callback=self.parse_results)"
msgstr ""

#: ../../../topics/request-response.rst:283
msgid ""
"Use ``data`` to override field values. To drop a field from the resulting "
"request, set its value to ``None``."
msgstr ""

#: ../../../topics/request-response.rst:286
msgid ""
"By default, form2request simulates clicking the first submit button. To "
"submit without clicking any button, pass ``click=False``. To click a "
"specific submit button, pass its element:"
msgstr ""

#: ../../../topics/request-response.rst:290
msgid ""
"def parse(self, response):\n"
"    form = response.css(\"form#checkout\")\n"
"    submit = form.css('button[name=\"pay\"]')\n"
"    request_data = form2request(form, click=submit)"
msgstr ""

#: ../../../topics/request-response.rst:300
msgid "Using form2request to simulate a user login"
msgstr ""

#: ../../../topics/request-response.rst:302
msgid ""
"It is usual for web sites to provide pre-populated form fields through "
"``<input type=\"hidden\">`` elements, such as session related data or "
"authentication tokens (for login pages). Build the request from the form and "
"only override the credentials:"
msgstr ""

#: ../../../topics/request-response.rst:307
msgid ""
"import scrapy\n"
"from form2request import form2request\n"
"\n"
"\n"
"class LoginSpider(scrapy.Spider):\n"
"    name = \"example.com\"\n"
"    start_urls = [\"http://www.example.com/users/login.php\"]\n"
"\n"
"    def parse(self, response):\n"
"        form = response.css(\"form\")\n"
"        request_data = form2request(\n"
"            form,\n"
"            data={\"username\": \"john\", \"password\": \"secret\"},\n"
"        )\n"
"        yield request_data.to_scrapy(callback=self.after_login)\n"
"\n"
"    def after_login(self, response): ..."
msgstr ""

