#: itemloaders.ItemLoader.add_jmes:15
msgid ""
"# HTML snippet: {\"name\": \"Color TV\"}\n"
"loader.add_jmes('name')\n"
"# HTML snippet: {\"price\": the price is $1200\"}\n"
"loader.add_jmes('price', TakeFirst(), re='the price is (.*)')"
msgstr ""

#: ../../../../scrapy/loader/__init__.py:docstring of
#: itemloaders.ItemLoader.add_value:1
msgid "Process and then add the given ``value`` for the given field."
msgstr ""

#: ../../../../scrapy/loader/__init__.py:docstring of
#: itemloaders.ItemLoader.add_value:3
msgid ""
"The value is first passed through :meth:`get_value` by giving the "
"``processors`` and ``kwargs``, and then passed through the :ref:`field input "
"processor <processors>` and its result appended to the data collected for "
"that field. If the field already contains collected data, the new data is "
"added."
msgstr ""

#: ../../../../scrapy/loader/__init__.py:docstring of
#: itemloaders.ItemLoader.add_value:9
msgid ""
"The given ``field_name`` can be ``None``, in which case values for multiple "
"fields may be added. And the processed value should be a dict with "
"field_name mapped to values."
msgstr ""

#: ../../../../scrapy/loader/__init__.py:docstring of
#: itemloaders.ItemLoader.add_value:18
msgid ""
"loader.add_value('name', 'Color TV')\n"
"loader.add_value('colours', ['white', 'blue'])\n"
"loader.add_value('length', '100')\n"
"loader.add_value('name', 'name: foo', TakeFirst(), re='name: (.+)')\n"
"loader.add_value(None, {'name': 'foo', 'sex': 'male'})"
msgstr ""

#: ../../../../scrapy/loader/__init__.py:docstring of
#: itemloaders.ItemLoader.add_xpath:1
msgid ""
"Similar to :meth:`ItemLoader.add_value` but receives an XPath instead of a "
"value, which is used to extract a list of strings from the selector "
