msgstr "提出异常了"

#: ../../../topics/spider-middleware.rst:172
msgid "Universal spider middlewares"
msgstr ""

#: ../../../topics/spider-middleware.rst:174
msgid ""
"In Scrapy 2.6.3 and lower, ``process_spider_output()`` must be a "
"*synchronous* generator."
msgstr ""

#: ../../../topics/spider-middleware.rst:177
msgid ""
"To support those versions and higher Scrapy versions in the same middleware, "
"rename your asynchronous :meth:`~SpiderMiddleware.process_spider_output` "
"method to :meth:`~SpiderMiddleware.process_spider_output_async`, and define "
"a synchronous ``process_spider_output()`` method to be used by 2.6.3 and "
"lower versions."
msgstr ""

#: ../../../topics/spider-middleware.rst:183
msgid "For example:"
msgstr "例如："

#: ../../../topics/spider-middleware.rst:185
msgid ""
"class UniversalSpiderMiddleware:\n"
"    async def process_spider_output_async(self, response, result):\n"
"        async for r in result:\n"
"            # ... do something with r\n"
"            yield r\n"
"\n"
"    def process_spider_output(self, response, result):\n"
"        for r in result:\n"
"            # ... do something with r\n"
"            yield r"
msgstr ""

