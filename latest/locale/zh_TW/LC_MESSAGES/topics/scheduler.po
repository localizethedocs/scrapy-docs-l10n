#: ../../../topics/scheduler.rst:5
msgid "Scheduler"
msgstr ""

#: ../../../topics/scheduler.rst:9
msgid ""
"The scheduler component receives requests from the :ref:`engine <component-"
"engine>` and stores them into persistent and/or non-persistent data "
"structures. It also gets those requests and feeds them back to the engine "
"when it asks for a next request to be downloaded."
msgstr ""

#: ../../../topics/scheduler.rst:16
msgid "Overriding the default scheduler"
msgstr ""

#: ../../../topics/scheduler.rst:18
msgid ""
"You can use your own custom scheduler class by supplying its full Python "
"path in the :setting:`SCHEDULER` setting."
msgstr ""

#: ../../../topics/scheduler.rst:23
msgid "Minimal scheduler interface"
msgstr ""

#: ../../../../scrapy/core/scheduler.py:docstring of
#: scrapy.core.scheduler.BaseScheduler:1
msgid ""
"The scheduler component is responsible for storing requests received from "
"the engine, and feeding them back upon request (also to the engine)."
msgstr ""

