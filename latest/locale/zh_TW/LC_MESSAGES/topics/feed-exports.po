"        'indent': 8,\n"
"    },\n"
"    pathlib.Path('items.csv.gz'): {\n"
"        'format': 'csv',\n"
"        'fields': ['price', 'name'],\n"
"        'item_filter': 'myproject.filters.MyCustomFilter2',\n"
"        'postprocessing': [MyPlugin1, 'scrapy.extensions.postprocessing."
"GzipPlugin'],\n"
"        'gzip_compresslevel': 5,\n"
"    },\n"
"}"
msgstr ""

#: ../../../topics/feed-exports.rst:464
msgid ""
"The following is a list of the accepted keys and the setting that is used as "
"a fallback value if that key is not provided for a specific feed definition:"
msgstr ""

#: ../../../topics/feed-exports.rst:467
msgid "``format``: the :ref:`serialization format <topics-feed-format>`."
msgstr ""

#: ../../../topics/feed-exports.rst:469
msgid "This setting is mandatory, there is no fallback value."
msgstr ""

#: ../../../topics/feed-exports.rst:471
msgid ""
"``batch_item_count``: falls back to :setting:`FEED_EXPORT_BATCH_ITEM_COUNT`."
msgstr ""

#: ../../../topics/feed-exports.rst:474
msgid "``encoding``: falls back to :setting:`FEED_EXPORT_ENCODING`."
msgstr ""

#: ../../../topics/feed-exports.rst:476
msgid "``fields``: falls back to :setting:`FEED_EXPORT_FIELDS`."
msgstr ""

#: ../../../topics/feed-exports.rst:478
msgid "``item_classes``: list of :ref:`item classes <topics-items>` to export."
msgstr ""

#: ../../../topics/feed-exports.rst:480
msgid "If undefined or empty, all items are exported."
msgstr ""

#: ../../../topics/feed-exports.rst:482
msgid ""
"``item_filter``: a :ref:`filter class <item-filter>` to filter items to "
"export."
msgstr ""

#: ../../../topics/feed-exports.rst:484
msgid ":class:`~scrapy.extensions.feedexport.ItemFilter` is used be default."
msgstr ""

#: ../../../topics/feed-exports.rst:486
msgid "``indent``: falls back to :setting:`FEED_EXPORT_INDENT`."
msgstr ""

#: ../../../topics/feed-exports.rst:488
msgid ""
"``item_export_kwargs``: :class:`dict` with keyword arguments for the "
"corresponding :ref:`item exporter class <topics-exporters>`."
msgstr ""

#: ../../../topics/feed-exports.rst:490
msgid ""
"``overwrite``: whether to overwrite the file if it already exists (``True``) "
"or append to its content (``False``)."
msgstr ""

#: ../../../topics/feed-exports.rst:493
msgid ""
"The default value depends on the :ref:`storage backend <topics-feed-storage-"
"backends>`:"
msgstr ""

#: ../../../topics/feed-exports.rst:496
msgid ":ref:`topics-feed-storage-fs`: ``False``"
msgstr ""

#: ../../../topics/feed-exports.rst:498
msgid ":ref:`topics-feed-storage-ftp`: ``True``"
msgstr ""

#: ../../../topics/feed-exports.rst:500
msgid ""
"Some FTP servers may not support appending to files (the ``APPE`` FTP "
"command)."
msgstr ""

#: ../../../topics/feed-exports.rst:503
msgid ":ref:`topics-feed-storage-s3`: ``True`` (appending is not supported)"
msgstr ""

#: ../../../topics/feed-exports.rst:505
msgid ":ref:`topics-feed-storage-gcs`: ``True`` (appending is not supported)"
msgstr ""

#: ../../../topics/feed-exports.rst:507
msgid ""
":ref:`topics-feed-storage-stdout`: ``False`` (overwriting is not supported)"
msgstr ""

#: ../../../topics/feed-exports.rst:509
msgid "``store_empty``: falls back to :setting:`FEED_STORE_EMPTY`."
msgstr ""

#: ../../../topics/feed-exports.rst:511
msgid "``uri_params``: falls back to :setting:`FEED_URI_PARAMS`."
msgstr ""

#: ../../../topics/feed-exports.rst:513
msgid ""
"``postprocessing``: list of :ref:`plugins <post-processing>` to use for post-"
"processing."
msgstr ""

#: ../../../topics/feed-exports.rst:515
msgid "The plugins will be used in the order of the list passed."
msgstr ""

#: ../../../topics/feed-exports.rst:520
msgid "FEED_EXPORT_ENCODING"
msgstr ""

#: ../../../topics/feed-exports.rst:522
msgid "Default: ``\"utf-8\"`` (:ref:`fallback <default-settings>`: ``None``)"
msgstr ""

#: ../../../topics/feed-exports.rst:524
msgid "The encoding to be used for the feed."
msgstr ""

#: ../../../topics/feed-exports.rst:526
msgid ""
"If set to ``None``, it uses UTF-8 for everything except JSON output, which "
"uses safe numeric encoding (``\\uXXXX`` sequences) for historic reasons."
msgstr ""

#: ../../../topics/feed-exports.rst:529
msgid "Use ``\"utf-8\"`` if you want UTF-8 for JSON too."
msgstr ""

#: ../../../topics/feed-exports.rst:531
msgid ""
"The :command:`startproject` command now sets this setting to ``\"utf-8\"`` "
"in the generated ``settings.py`` file."
msgstr ""

#: ../../../topics/feed-exports.rst:538
msgid "FEED_EXPORT_FIELDS"
msgstr ""

#: ../../../topics/feed-exports.rst:540 ../../../topics/feed-exports.rst:729
msgid "Default: ``None``"
msgstr ""

#: ../../../topics/feed-exports.rst:542
msgid ""
"Use the ``FEED_EXPORT_FIELDS`` setting to define the fields to export, their "
"order and their output names. See :attr:`BaseItemExporter.fields_to_export "
"<scrapy.exporters.BaseItemExporter.fields_to_export>` for more information."
msgstr ""

#: ../../../topics/feed-exports.rst:549
msgid "FEED_EXPORT_INDENT"
msgstr ""

#: ../../../topics/feed-exports.rst:551 ../../../topics/feed-exports.rst:683
msgid "Default: ``0``"
msgstr ""

#: ../../../topics/feed-exports.rst:553
msgid ""
"Amount of spaces used to indent the output on each level. If "
"``FEED_EXPORT_INDENT`` is a non-negative integer, then array elements and "
"object members will be pretty-printed with that indent level. An indent "
"level of ``0`` (the default), or negative, will put each item on a new line. "
"``None`` selects the most compact representation."
msgstr ""

#: ../../../topics/feed-exports.rst:558
msgid ""
"Currently implemented only by :class:`~scrapy.exporters.JsonItemExporter` "
"and :class:`~scrapy.exporters.XmlItemExporter`, i.e. when you are exporting "
"to ``.json`` or ``.xml``."
msgstr ""

#: ../../../topics/feed-exports.rst:565
msgid "FEED_STORE_EMPTY"
msgstr ""

#: ../../../topics/feed-exports.rst:567
msgid "Default: ``True``"
msgstr ""

#: ../../../topics/feed-exports.rst:569
msgid ""
"Whether to export empty feeds (i.e. feeds with no items). If ``False``, and "
"there are no items to export, no new files are created and existing files "
"are not modified, even if the :ref:`overwrite feed option <feed-options>` is "
"enabled."
msgstr ""

#: ../../../topics/feed-exports.rst:577
msgid "FEED_STORAGES"
msgstr ""

#: ../../../topics/feed-exports.rst:581
msgid ""
"A dict containing additional feed storage backends supported by your "
"project. The keys are URI schemes and the values are paths to storage "
"classes."
msgstr ""

#: ../../../topics/feed-exports.rst:587
msgid "FEED_STORAGE_FTP_ACTIVE"
msgstr ""

#: ../../../topics/feed-exports.rst:589
msgid "Default: ``False``"
msgstr ""

#: ../../../topics/feed-exports.rst:591
msgid ""
"Whether to use the active connection mode when exporting feeds to an FTP "
"server (``True``) or use the passive connection mode instead (``False``, "
"default)."
msgstr ""

#: ../../../topics/feed-exports.rst:594
msgid ""
"For information about FTP connection modes, see `What is the difference "
"between active and passive FTP? <https://stackoverflow.com/a/1699163>`_."
msgstr ""

#: ../../../topics/feed-exports.rst:600
msgid "FEED_STORAGE_S3_ACL"
msgstr ""

#: ../../../topics/feed-exports.rst:602
msgid "Default: ``''`` (empty string)"
msgstr ""

#: ../../../topics/feed-exports.rst:604
msgid ""
"A string containing a custom ACL for feeds exported to Amazon S3 by your "
"project."
msgstr ""

#: ../../../topics/feed-exports.rst:606
msgid ""
"For a complete list of available values, access the `Canned ACL`_ section on "
"Amazon S3 docs."
msgstr ""

#: ../../../topics/feed-exports.rst:611
msgid "FEED_STORAGES_BASE"
msgstr ""

#: ../../../topics/feed-exports.rst:613 ../../../topics/feed-exports.rst:651
msgid "Default:"
msgstr ""

#: ../../../topics/feed-exports.rst:615
msgid ""
"{\n"
"    \"\": \"scrapy.extensions.feedexport.FileFeedStorage\",\n"
"    \"file\": \"scrapy.extensions.feedexport.FileFeedStorage\",\n"
"    \"stdout\": \"scrapy.extensions.feedexport.StdoutFeedStorage\",\n"
"    \"s3\": \"scrapy.extensions.feedexport.S3FeedStorage\",\n"
"    \"ftp\": \"scrapy.extensions.feedexport.FTPFeedStorage\",\n"
"}"
msgstr ""

#: ../../../topics/feed-exports.rst:625
msgid ""
"A dict containing the built-in feed storage backends supported by Scrapy. "
"You can disable any of these backends by assigning ``None`` to their URI "
"scheme in :setting:`FEED_STORAGES`. E.g., to disable the built-in FTP "
"storage backend (without replacement), place this in your ``settings.py``:"
msgstr ""

#: ../../../topics/feed-exports.rst:630
msgid ""
"FEED_STORAGES = {\n"
"    \"ftp\": None,\n"
"}"
msgstr ""

#: ../../../topics/feed-exports.rst:639
msgid "FEED_EXPORTERS"
msgstr ""

#: ../../../topics/feed-exports.rst:643
msgid ""
"A dict containing additional exporters supported by your project. The keys "
"are serialization formats and the values are paths to :ref:`Item exporter "
"<topics-exporters>` classes."
msgstr ""

#: ../../../topics/feed-exports.rst:650
msgid "FEED_EXPORTERS_BASE"
msgstr ""

#: ../../../topics/feed-exports.rst:653
msgid ""
"{\n"
"    \"json\": \"scrapy.exporters.JsonItemExporter\",\n"
"    \"jsonlines\": \"scrapy.exporters.JsonLinesItemExporter\",\n"
"    \"jsonl\": \"scrapy.exporters.JsonLinesItemExporter\",\n"
"    \"jl\": \"scrapy.exporters.JsonLinesItemExporter\",\n"
"    \"csv\": \"scrapy.exporters.CsvItemExporter\",\n"
"    \"xml\": \"scrapy.exporters.XmlItemExporter\",\n"
"    \"marshal\": \"scrapy.exporters.MarshalItemExporter\",\n"
"    \"pickle\": \"scrapy.exporters.PickleItemExporter\",\n"
"}"
msgstr ""

#: ../../../topics/feed-exports.rst:666
msgid ""
"A dict containing the built-in feed exporters supported by Scrapy. You can "
"disable any of these exporters by assigning ``None`` to their serialization "
"format in :setting:`FEED_EXPORTERS`. E.g., to disable the built-in CSV "
"exporter (without replacement), place this in your ``settings.py``:"
msgstr ""

#: ../../../topics/feed-exports.rst:671
msgid ""
"FEED_EXPORTERS = {\n"
"    \"csv\": None,\n"
"}"
msgstr ""

#: ../../../topics/feed-exports.rst:681
msgid "FEED_EXPORT_BATCH_ITEM_COUNT"
msgstr ""

#: ../../../topics/feed-exports.rst:685
msgid ""
"If assigned an integer number higher than ``0``, Scrapy generates multiple "
"output files storing up to the specified number of items in each output file."
msgstr ""

#: ../../../topics/feed-exports.rst:688
msgid ""
"When generating multiple output files, you must use at least one of the "
"following placeholders in the feed URI to indicate how the different output "
"file names are generated:"
msgstr ""

#: ../../../topics/feed-exports.rst:692
msgid ""
"``%(batch_time)s`` - gets replaced by a timestamp when the feed is being "
"created (e.g. ``2020-03-28T14-45-08.237134``)"
msgstr ""

#: ../../../topics/feed-exports.rst:695
msgid ""
"``%(batch_id)d`` - gets replaced by the 1-based sequence number of the batch."
msgstr ""

#: ../../../topics/feed-exports.rst:697
msgid ""
"Use :ref:`printf-style string formatting <python:old-string-formatting>` to "
"alter the number format. For example, to make the batch ID a 5-digit number "
"by introducing leading zeroes as needed, use ``%(batch_id)05d`` (e.g. ``3`` "
"becomes ``00003``, ``123`` becomes ``00123``)."
msgstr ""

#: ../../../topics/feed-exports.rst:702
msgid "For instance, if your settings include:"
msgstr ""

#: ../../../topics/feed-exports.rst:704
msgid "FEED_EXPORT_BATCH_ITEM_COUNT = 100"
msgstr ""

#: ../../../topics/feed-exports.rst:708
msgid "And your :command:`crawl` command line is::"
msgstr ""

#: ../../../topics/feed-exports.rst:710
msgid ""
"scrapy crawl spidername -o \"dirname/%(batch_id)d-filename%(batch_time)s."
"json\""
msgstr ""

#: ../../../topics/feed-exports.rst:712
msgid "The command line above can generate a directory tree like::"
msgstr ""

#: ../../../topics/feed-exports.rst:714
msgid ""
"->projectname\n"
"-->dirname\n"
"--->1-filename2020-03-28T14-45-08.237134.json\n"
"--->2-filename2020-03-28T14-45-09.148903.json\n"
"--->3-filename2020-03-28T14-45-10.046092.json"
msgstr ""

#: ../../../topics/feed-exports.rst:720
msgid ""
"Where the first and second files contain exactly 100 items. The last one "
"contains 100 items or fewer."
msgstr ""

#: ../../../topics/feed-exports.rst:727
msgid "FEED_URI_PARAMS"
msgstr ""

#: ../../../topics/feed-exports.rst:731
msgid ""
"A string with the import path of a function to set the parameters to apply "
"with :ref:`printf-style string formatting <python:old-string-formatting>` to "
"the feed URI."
