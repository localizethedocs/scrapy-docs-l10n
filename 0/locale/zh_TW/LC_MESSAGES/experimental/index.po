#: ../../../experimental/index.rst:20
msgid "Add commands using external libraries"
msgstr ""

#: ../../../experimental/index.rst:22
msgid ""
"You can also add Scrapy commands from an external library by adding `scrapy."
"commands` section into entry_points in the `setup.py`."
msgstr ""

#: ../../../experimental/index.rst:24
msgid "The following example adds `my_command` command::"
msgstr ""

#: ../../../experimental/index.rst:26
msgid ""
"from setuptools import setup, find_packages\n"
"\n"
"setup(name='scrapy-mymodule',\n"
"  entry_points={\n"
"    'scrapy.commands': [\n"
"      'my_command=my_scrapy_module.commands:MyCommand',\n"
"    ],\n"
"  },\n"
" )"
msgstr ""
