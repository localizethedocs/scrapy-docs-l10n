msgid "MEMUSAGE_LIMIT_MB"
msgstr ""

#: ../../../topics/settings.rst:611
msgid ""
"The maximum amount of memory to allow (in megabytes) before shutting down "
"Scrapy  (if MEMUSAGE_ENABLED is True). If zero, no check will be performed."
msgstr ""

#: ../../../topics/settings.rst:619
msgid "MEMUSAGE_NOTIFY_MAIL"
msgstr ""

#: ../../../topics/settings.rst:625
msgid "A list of emails to notify if the memory limit has been reached."
msgstr ""

#: ../../../topics/settings.rst:629
msgid "MEMUSAGE_NOTIFY_MAIL = ['user@example.com']"
msgstr ""

#: ../../../topics/settings.rst:636
msgid "MEMUSAGE_REPORT"
msgstr ""

#: ../../../topics/settings.rst:642
msgid ""
"Whether to send a memory usage report after each spider has been closed."
msgstr ""

#: ../../../topics/settings.rst:649
msgid "MEMUSAGE_WARNING_MB"
msgstr ""

#: ../../../topics/settings.rst:655
msgid ""
"The maximum amount of memory to allow (in megabytes) before sending a "
"warning email notifying about it. If zero, no warning will be produced."
msgstr ""

#: ../../../topics/settings.rst:661
msgid "NEWSPIDER_MODULE"
msgstr ""

#: ../../../topics/settings.rst:663
msgid "Default: ``''``"
msgstr ""

#: ../../../topics/settings.rst:665
msgid ""
"Module where to create new spiders using the :command:`genspider` command."
msgstr ""

#: ../../../topics/settings.rst:669
msgid "NEWSPIDER_MODULE = 'mybot.spiders_dev'"
msgstr ""

#: ../../../topics/settings.rst:674
msgid "RANDOMIZE_DOWNLOAD_DELAY"
msgstr ""

#: ../../../topics/settings.rst:678
msgid ""
"If enabled, Scrapy will wait a random amount of time (between 0.5 and 1.5 * :"
"setting:`DOWNLOAD_DELAY`) while fetching requests from the same website."
msgstr ""

#: ../../../topics/settings.rst:682
msgid ""
"This randomization decreases the chance of the crawler being detected (and "
"subsequently blocked) by sites which analyze requests looking for "
"statistically significant similarities in the time between their requests."
msgstr ""

#: ../../../topics/settings.rst:686
msgid ""
"The randomization policy is the same used by `wget`_ ``--random-wait`` "
"option."
msgstr ""

#: ../../../topics/settings.rst:688
msgid ""
"If :setting:`DOWNLOAD_DELAY` is zero (default) this option has no effect."
msgstr ""

#: ../../../topics/settings.rst:695
msgid "REDIRECT_MAX_TIMES"
msgstr ""

#: ../../../topics/settings.rst:697
msgid "Default: ``20``"
msgstr ""

#: ../../../topics/settings.rst:699
msgid ""
"Defines the maximum times a request can be redirected. After this maximum "
"the request's response is returned as is. We used Firefox default value for "
"the same task."
msgstr ""

#: ../../../topics/settings.rst:706
msgid "REDIRECT_MAX_METAREFRESH_DELAY"
msgstr ""

#: ../../../topics/settings.rst:710
msgid ""
"Some sites use meta-refresh for redirecting to a session expired page, so we "
"restrict automatic redirection to a maximum delay (in seconds)"
msgstr ""

#: ../../../topics/settings.rst:716
msgid "REDIRECT_PRIORITY_ADJUST"
msgstr ""

#: ../../../topics/settings.rst:718
msgid "Default: ``+2``"
msgstr ""

#: ../../../topics/settings.rst:720
msgid ""
"Adjust redirect request priority relative to original request. A negative "
"priority adjust means more priority."
msgstr ""

#: ../../../topics/settings.rst:726
msgid "ROBOTSTXT_OBEY"
msgstr ""

#: ../../../topics/settings.rst:730
msgid "Scope: ``scrapy.contrib.downloadermiddleware.robotstxt``"
msgstr ""

#: ../../../topics/settings.rst:732
msgid ""
"If enabled, Scrapy will respect robots.txt policies. For more information "
"see :ref:`topics-dlmw-robots`"
msgstr ""

#: ../../../topics/settings.rst:738
msgid "SCHEDULER"
msgstr ""

#: ../../../topics/settings.rst:740
msgid "Default: ``'scrapy.core.scheduler.Scheduler'``"
msgstr ""

#: ../../../topics/settings.rst:742
msgid "The scheduler to use for crawling."
msgstr ""

#: ../../../topics/settings.rst:747
msgid "SPIDER_CONTRACTS"
msgstr ""

#: ../../../topics/settings.rst:751
msgid ""
"A dict containing the scrapy contracts enabled in your project, used for "
"testing spiders. For more info see :ref:`topics-contracts`."
msgstr ""

#: ../../../topics/settings.rst:757
msgid "SPIDER_CONTRACTS_BASE"
msgstr ""

#: ../../../topics/settings.rst:761
msgid ""
"{\n"
"    'scrapy.contracts.default.UrlContract' : 1,\n"
"    'scrapy.contracts.default.ReturnsContract': 2,\n"
"    'scrapy.contracts.default.ScrapesContract': 3,\n"
"}"
msgstr ""

#: ../../../topics/settings.rst:767
msgid ""
"A dict containing the scrapy contracts enabled by default in Scrapy. You "
"should never modify this setting in your project, modify :setting:"
"`SPIDER_CONTRACTS` instead. For more info see :ref:`topics-contracts`."
msgstr ""

#: ../../../topics/settings.rst:774
msgid "SPIDER_MIDDLEWARES"
msgstr ""

#: ../../../topics/settings.rst:778
msgid ""
"A dict containing the spider middlewares enabled in your project, and their "
"orders. For more info see :ref:`topics-spider-middleware-setting`."
msgstr ""

#: ../../../topics/settings.rst:784
msgid "SPIDER_MIDDLEWARES_BASE"
msgstr ""

#: ../../../topics/settings.rst:788
msgid ""
"{\n"
"    'scrapy.contrib.spidermiddleware.httperror.HttpErrorMiddleware': 50,\n"
"    'scrapy.contrib.spidermiddleware.offsite.OffsiteMiddleware': 500,\n"
"    'scrapy.contrib.spidermiddleware.referer.RefererMiddleware': 700,\n"
"    'scrapy.contrib.spidermiddleware.urllength.UrlLengthMiddleware': 800,\n"
"    'scrapy.contrib.spidermiddleware.depth.DepthMiddleware': 900,\n"
"}"
msgstr ""

#: ../../../topics/settings.rst:796
msgid ""
"A dict containing the spider middlewares enabled by default in Scrapy. You "
"should never modify this setting in your project, modify :setting:"
"`SPIDER_MIDDLEWARES` instead. For more info see :ref:`topics-spider-"
"middleware-setting`."
msgstr ""

#: ../../../topics/settings.rst:804
msgid "SPIDER_MODULES"
msgstr ""

#: ../../../topics/settings.rst:808
msgid "A list of modules where Scrapy will look for spiders."
msgstr ""

#: ../../../topics/settings.rst:812
msgid "SPIDER_MODULES = ['mybot.spiders_prod', 'mybot.spiders_dev']"
msgstr ""

#: ../../../topics/settings.rst:817
msgid "STATS_CLASS"
msgstr ""

#: ../../../topics/settings.rst:819
msgid "Default: ``'scrapy.statscol.MemoryStatsCollector'``"
msgstr ""

#: ../../../topics/settings.rst:821
msgid ""
"The class to use for collecting stats, who must implement the :ref:`topics-"
"api-stats`."
msgstr ""

#: ../../../topics/settings.rst:827
msgid "STATS_DUMP"
msgstr ""

#: ../../../topics/settings.rst:831
msgid ""
"Dump the :ref:`Scrapy stats <topics-stats>` (to the Scrapy log) once the "
"spider finishes."
msgstr ""

#: ../../../topics/settings.rst:834
msgid "For more info see: :ref:`topics-stats`."
msgstr ""

#: ../../../topics/settings.rst:839
msgid "STATSMAILER_RCPTS"
msgstr ""

#: ../../../topics/settings.rst:841
msgid "Default: ``[]`` (empty list)"
msgstr ""

#: ../../../topics/settings.rst:843
msgid ""
"Send Scrapy stats after spiders finish scraping. See :class:`~scrapy.contrib."
"statsmailer.StatsMailer` for more info."
msgstr ""

#: ../../../topics/settings.rst:849
msgid "TELNETCONSOLE_ENABLED"
msgstr ""

#: ../../../topics/settings.rst:853
msgid ""
"A boolean which specifies if the :ref:`telnet console <topics-"
"telnetconsole>` will be enabled (provided its extension is also enabled)."
msgstr ""

#: ../../../topics/settings.rst:859
msgid "TELNETCONSOLE_PORT"
msgstr ""

#: ../../../topics/settings.rst:861
msgid "Default: ``[6023, 6073]``"
msgstr ""

#: ../../../topics/settings.rst:863
msgid ""
"The port range to use for the telnet console. If set to ``None`` or ``0``, a "
"dynamically assigned port is used. For more info see :ref:`topics-"
"telnetconsole`."
msgstr ""

#: ../../../topics/settings.rst:870
msgid "TEMPLATES_DIR"
msgstr ""

#: ../../../topics/settings.rst:872
msgid "Default: ``templates`` dir inside scrapy module"
msgstr ""

#: ../../../topics/settings.rst:874
msgid ""
"The directory where to look for templates when creating new projects with :"
"command:`startproject` command."
msgstr ""

#: ../../../topics/settings.rst:880
msgid "URLLENGTH_LIMIT"
msgstr ""

#: ../../../topics/settings.rst:882
msgid "Default: ``2083``"
msgstr ""

#: ../../../topics/settings.rst:884
msgid "Scope: ``contrib.spidermiddleware.urllength``"
msgstr ""

#: ../../../topics/settings.rst:886
msgid ""
"The maximum URL length to allow for crawled URLs. For more information about "
"the default value for this setting see: http://www.boutell.com/newfaq/misc/"
"urllength.html"
msgstr ""

#: ../../../topics/settings.rst:892
msgid "USER_AGENT"
msgstr ""

#: ../../../topics/settings.rst:894
msgid "Default: ``\"Scrapy/VERSION (+http://scrapy.org)\"``"
msgstr ""

#: ../../../topics/settings.rst:896
msgid "The default User-Agent to use when crawling, unless overridden."
msgstr ""
