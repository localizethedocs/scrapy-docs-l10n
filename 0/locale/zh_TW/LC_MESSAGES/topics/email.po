msgid "MAIL_FROM"
msgstr ""

#: ../../../topics/email.rst:120
msgid "Default: ``'scrapy@localhost'``"
msgstr ""

#: ../../../topics/email.rst:122
msgid "Sender email to use (``From:`` header) for sending emails."
msgstr ""

