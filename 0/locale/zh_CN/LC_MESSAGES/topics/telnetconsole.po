#: ../../../topics/telnetconsole.rst:77
msgid "View engine status"
msgstr ""

#: ../../../topics/telnetconsole.rst:79
msgid ""
"You can use the ``est()`` method of the Scrapy engine to quickly show its "
"state using the telnet console::"
msgstr ""

#: ../../../topics/telnetconsole.rst:82
msgid ""
"telnet localhost 6023\n"
">>> est()\n"
"Execution engine status\n"
"\n"
"time()-engine.start_time                        : 8.62972998619\n"
"engine.has_capacity()                           : False\n"
"len(engine.downloader.active)                   : 16\n"
"engine.scraper.is_idle()                        : False\n"
"engine.spider.name                              : followall\n"
"engine.spider_is_idle(engine.spider)            : False\n"
"engine.slot.closing                             : False\n"
"len(engine.slot.inprogress)                     : 16\n"
"len(engine.slot.scheduler.dqs or [])            : 0\n"
"len(engine.slot.scheduler.mqs)                  : 92\n"
"len(engine.scraper.slot.queue)                  : 0\n"
"len(engine.scraper.slot.active)                 : 0\n"
"engine.scraper.slot.active_size                 : 0\n"
"engine.scraper.slot.itemproc_size               : 0\n"
"engine.scraper.slot.needs_backout()             : False"
msgstr ""

#: ../../../topics/telnetconsole.rst:104
msgid "Pause, resume and stop the Scrapy engine"
msgstr ""

#: ../../../topics/telnetconsole.rst:106
msgid "To pause::"
msgstr ""

#: ../../../topics/telnetconsole.rst:108
msgid ""
"telnet localhost 6023\n"
">>> engine.pause()\n"
">>>"
msgstr ""

#: ../../../topics/telnetconsole.rst:112
msgid "To resume::"
msgstr ""

#: ../../../topics/telnetconsole.rst:114
msgid ""
"telnet localhost 6023\n"
">>> engine.unpause()\n"
">>>"
msgstr ""

#: ../../../topics/telnetconsole.rst:118
msgid "To stop::"
msgstr ""

#: ../../../topics/telnetconsole.rst:120
msgid ""
"telnet localhost 6023\n"
">>> engine.stop()\n"
"Connection closed by foreign host."
msgstr ""

