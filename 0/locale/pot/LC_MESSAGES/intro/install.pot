#: ../../../intro/install.rst:18
msgid "Installing Scrapy"
msgstr ""

#: ../../../intro/install.rst:20
msgid ""
"You can install Scrapy using easy_install or pip (which is the canonical way "
"to distribute and install Python packages)."
msgstr ""

#: ../../../intro/install.rst:23
msgid "Check :ref:`intro-install-platform-notes` first."
msgstr ""

