#: ../../../topics/settings.rst:855
msgid "DOWNLOADER_STATS"
msgstr ""

#: ../../../topics/settings.rst:859
msgid "Whether to enable downloader stats collection."
msgstr ""

#: ../../../topics/settings.rst:864
msgid "DOWNLOAD_DELAY"
msgstr ""

#: ../../../topics/settings.rst:866
msgid "Default: ``1`` (:ref:`fallback <default-settings>`: ``0``)"
msgstr ""

#: ../../../topics/settings.rst:868
msgid ""
"Minimum seconds to wait between 2 consecutive requests to the same domain."
msgstr ""

#: ../../../topics/settings.rst:870
msgid ""
"Use :setting:`DOWNLOAD_DELAY` to throttle your crawling speed, to avoid "
"hitting servers too hard."
msgstr ""

#: ../../../topics/settings.rst:873
msgid ""
"Decimal numbers are supported. For example, to send a maximum of 4 requests "
"every 10 seconds::"
msgstr ""

#: ../../../topics/settings.rst:876
msgid "DOWNLOAD_DELAY = 2.5"
msgstr ""

#: ../../../topics/settings.rst:878
msgid ""
"This setting is also affected by the :setting:`RANDOMIZE_DOWNLOAD_DELAY` "
"setting, which is enabled by default."
msgstr ""

#: ../../../topics/settings.rst:881
msgid ""
"Note that :setting:`DOWNLOAD_DELAY` can lower the effective per-domain "
"concurrency below :setting:`CONCURRENT_REQUESTS_PER_DOMAIN`. If the response "
"time of a domain is lower than :setting:`DOWNLOAD_DELAY`, the effective "
"concurrency for that domain is 1. When testing throttling configurations, it "
"usually makes sense to lower :setting:`CONCURRENT_REQUESTS_PER_DOMAIN` "
"first, and only increase :setting:`DOWNLOAD_DELAY` once :setting:"
"`CONCURRENT_REQUESTS_PER_DOMAIN` is 1 but a higher throttling is desired."
msgstr ""

#: ../../../topics/settings.rst:894
msgid ""
"This delay can be set per spider using :attr:`download_delay` spider "
"attribute."
msgstr ""

#: ../../../topics/settings.rst:896
msgid ""
"It is also possible to change this setting per domain, although it requires "
"non-trivial code. See the implementation of the :ref:`AutoThrottle <topics-"
"autothrottle>` extension for an example."
msgstr ""

#: ../../../topics/settings.rst:903
msgid "DOWNLOAD_HANDLERS"
msgstr ""

#: ../../../topics/settings.rst:907
msgid ""
"A dict containing the :ref:`download handlers <topics-download-handlers>` "
"enabled in your project."
msgstr ""

#: ../../../topics/settings.rst:910
msgid "See :setting:`DOWNLOAD_HANDLERS_BASE` for example format."
msgstr ""

#: ../../../topics/settings.rst:915
msgid "DOWNLOAD_HANDLERS_BASE"
msgstr ""

#: ../../../topics/settings.rst:919
msgid ""
"{\n"
"    \"data\": \"scrapy.core.downloader.handlers.datauri."
"DataURIDownloadHandler\",\n"
"    \"file\": \"scrapy.core.downloader.handlers.file.FileDownloadHandler\",\n"
"    \"http\": \"scrapy.core.downloader.handlers.http11."
"HTTP11DownloadHandler\",\n"
"    \"https\": \"scrapy.core.downloader.handlers.http11."
"HTTP11DownloadHandler\",\n"
"    \"s3\": \"scrapy.core.downloader.handlers.s3.S3DownloadHandler\",\n"
"    \"ftp\": \"scrapy.core.downloader.handlers.ftp.FTPDownloadHandler\",\n"
"}"
msgstr ""

#: ../../../topics/settings.rst:931
msgid ""
"A dict containing the :ref:`download handlers <topics-download-handlers>` "
"enabled by default in Scrapy. You should never modify this setting in your "
"project, modify :setting:`DOWNLOAD_HANDLERS` instead."
msgstr ""

#: ../../../topics/settings.rst:935
msgid ""
"You can disable any of these download handlers by assigning ``None`` to "
"their URI scheme in :setting:`DOWNLOAD_HANDLERS`. E.g., to disable the built-"
"in FTP handler (without replacement), place this in your ``settings.py``:"
msgstr ""

#: ../../../topics/settings.rst:939
msgid ""
"DOWNLOAD_HANDLERS = {\n"
"    \"ftp\": None,\n"
"}"
msgstr ""

#: ../../../topics/settings.rst:949
msgid "DOWNLOAD_SLOTS"
msgstr ""

#: ../../../topics/settings.rst:953
msgid ""
"Allows to define concurrency/delay parameters on per slot (domain) basis:"
msgstr ""

#: ../../../topics/settings.rst:955
msgid ""
"DOWNLOAD_SLOTS = {\n"
"    \"quotes.toscrape.com\": {\"concurrency\": 1, \"delay\": 2, "
"\"randomize_delay\": False},\n"
"    \"books.toscrape.com\": {\"delay\": 3, \"randomize_delay\": False},\n"
"}"
msgstr ""

#: ../../../topics/settings.rst:964
msgid "For other downloader slots default settings values will be used:"
msgstr ""

#: ../../../topics/settings.rst:966
msgid ":setting:`DOWNLOAD_DELAY`: ``delay``"
msgstr ""

#: ../../../topics/settings.rst:967
msgid ":setting:`CONCURRENT_REQUESTS_PER_DOMAIN`: ``concurrency``"
msgstr ""

#: ../../../topics/settings.rst:968
msgid ":setting:`RANDOMIZE_DOWNLOAD_DELAY`: ``randomize_delay``"
msgstr ""

#: ../../../topics/settings.rst:974
msgid "DOWNLOAD_TIMEOUT"
msgstr ""

#: ../../../topics/settings.rst:976
msgid "Default: ``180``"
msgstr ""

#: ../../../topics/settings.rst:978
msgid ""
"The amount of time (in secs) that the downloader will wait before timing out."
msgstr ""

#: ../../../topics/settings.rst:982
msgid ""
"This timeout can be per-request using the :reqmeta:`download_timeout` :attr:"
"`.Request.meta` key."
msgstr ""

#: ../../../topics/settings.rst:987 ../../../topics/settings.rst:1072
#: ../../../topics/settings.rst:1275 ../../../topics/settings.rst:1300
#: ../../../topics/settings.rst:1317
msgid ""
"Handling of this setting needs to be implemented inside the :ref:`download "
"handler <topics-download-handlers>`, so it's not guaranteed to be supported "
"by all 3rd-party handlers."
msgstr ""

#: ../../../topics/settings.rst:995
msgid "DOWNLOAD_MAXSIZE"
msgstr ""

#: ../../../topics/settings.rst:997
msgid "Default: ``1073741824`` (1 GiB)"
msgstr ""

#: ../../../topics/settings.rst:999
msgid ""
"The maximum response body size (in bytes) allowed. Bigger responses are "
"aborted and ignored."
msgstr ""

#: ../../../topics/settings.rst:1002
msgid ""
"This applies both before and after compression. If decompressing a response "
"body would exceed this limit, decompression is aborted and the response is "
"ignored."
msgstr ""

#: ../../../topics/settings.rst:1006 ../../../topics/settings.rst:1030
msgid "Use ``0`` to disable this limit."
msgstr ""

#: ../../../topics/settings.rst:1010
msgid ""
"This limit can be set per-request using the :reqmeta:`download_maxsize` :"
"attr:`.Request.meta` key."
msgstr ""

#: ../../../topics/settings.rst:1015 ../../../topics/settings.rst:1039
msgid ""
"Checking responses before decompressing them needs to be implemented inside "
"the :ref:`download handler <topics-download-handlers>`, so it's not "
"guaranteed to be supported by all 3rd-party handlers."
msgstr ""

#: ../../../topics/settings.rst:1023
msgid "DOWNLOAD_WARNSIZE"
msgstr ""

#: ../../../topics/settings.rst:1025
msgid "Default: ``33554432`` (32 MiB)"
msgstr ""

#: ../../../topics/settings.rst:1027
msgid ""
"If the size of a response exceeds this value, before or after compression, a "
"warning will be logged about it."
msgstr ""

#: ../../../topics/settings.rst:1034
msgid ""
"This limit can be set per-request using the :reqmeta:`download_warnsize` :"
"attr:`.Request.meta` key."
msgstr ""

#: ../../../topics/settings.rst:1046
msgid "DOWNLOAD_FAIL_ON_DATALOSS"
msgstr ""

#: ../../../topics/settings.rst:1050
msgid ""
"Whether or not to fail on broken responses, that is, when the declared "
"``Content-Length`` does not match content sent by the server or a chunked "
"response was not properly finished. If ``True``, these responses raise a :"
"exc:`~scrapy.exceptions.ResponseDataLossError` exception. If ``False``, "
"these responses are passed through and the flag ``dataloss`` is added to the "
"response, i.e.: ``'dataloss' in response.flags`` is ``True``."
msgstr ""

#: ../../../topics/settings.rst:1057
msgid ""
"Optionally, this can be set per-request basis by using the :reqmeta:"
"`download_fail_on_dataloss` Request.meta key to ``False``."
msgstr ""

#: ../../../topics/settings.rst:1062
msgid ""
"A broken response, or data loss error, may happen under several "
"circumstances, from server misconfiguration to network errors to data "
"corruption. It is up to the user to decide if it makes sense to process "
"broken responses considering they may contain partial or incomplete content. "
"If :setting:`RETRY_ENABLED` is ``True`` and this setting is set to ``True``, "
"the :exc:`~scrapy.exceptions.ResponseDataLossError` failure will be retried "
"as usual."
msgstr ""

#: ../../../topics/settings.rst:1078
msgid ""
"This setting is ignored by the :class:`~scrapy.core.downloader.handlers."
"http2.H2DownloadHandler` :ref:`download handler <topics-download-handlers>`. "
"In case of a data loss error, the corresponding HTTP/2 connection may be "
"corrupted, affecting other requests that use the same connection; hence, a "
"``ResponseFailed([InvalidBodyLengthError])`` failure is always raised for "
"every request that was using that connection."
msgstr ""

#: ../../../topics/settings.rst:1088
msgid "DUPEFILTER_CLASS"
msgstr ""

#: ../../../topics/settings.rst:1090
msgid "Default: ``'scrapy.dupefilters.RFPDupeFilter'``"
msgstr ""

#: ../../../topics/settings.rst:1092
msgid "The class used to detect and filter duplicate requests."
msgstr ""

#: ../../../topics/settings.rst:1094
msgid ""
"The default, :class:`~scrapy.dupefilters.RFPDupeFilter`, filters based on "
"the :setting:`REQUEST_FINGERPRINTER_CLASS` setting."
msgstr ""

#: ../../../topics/settings.rst:1097
msgid ""
"To change how duplicates are checked, you can point :setting:"
"`DUPEFILTER_CLASS` to a custom subclass of :class:`~scrapy.dupefilters."
"RFPDupeFilter` that overrides its ``__init__`` method to use a :ref:"
"`different request fingerprinting class <custom-request-fingerprinter>`. For "
"example:"
msgstr ""

#: ../../../topics/settings.rst:1102
msgid ""
"from scrapy.dupefilters import RFPDupeFilter\n"
"from scrapy.utils.request import fingerprint\n"
"\n"
"\n"
"class CustomRequestFingerprinter:\n"
"    def fingerprint(self, request):\n"
"        return fingerprint(request, include_headers=[\"X-ID\"])\n"
"\n"
"\n"
"class CustomDupeFilter(RFPDupeFilter):\n"
"\n"
"    def __init__(self, path=None, debug=False, *, fingerprinter=None):\n"
"        super().__init__(\n"
"            path=path, debug=debug, "
"fingerprinter=CustomRequestFingerprinter()\n"
"        )"
msgstr ""

#: ../../../topics/settings.rst:1120
msgid ""
"To disable duplicate request filtering set :setting:`DUPEFILTER_CLASS` to "
"``'scrapy.dupefilters.BaseDupeFilter'``. Note that not filtering out "
"duplicate requests may cause crawling loops. It is usually better to set the "
"``dont_filter`` parameter to ``True`` on the ``__init__`` method of a "
"specific :class:`~scrapy.Request` object that should not be filtered out."
msgstr ""

#: ../../../topics/settings.rst:1126
msgid ""
"A class assigned to :setting:`DUPEFILTER_CLASS` must implement the following "
"interface::"
msgstr ""

#: ../../../topics/settings.rst:1129
msgid ""
"class MyDupeFilter:\n"
"\n"
"    @classmethod\n"
"    def from_crawler(cls, crawler):\n"
"        \"\"\"Returns an instance of this duplicate request filtering class\n"
"        based on the current Crawler instance.\"\"\"\n"
"        return cls()\n"
"\n"
"    def request_seen(self, request):\n"
"        \"\"\"Returns ``True`` if *request* is a duplicate of another "
"request\n"
"        seen in a previous call to :meth:`request_seen`, or ``False``\n"
"        otherwise.\"\"\"\n"
"        return False\n"
"\n"
"    def open(self):\n"
"        \"\"\"Called before the spider opens. It may return a deferred."
"\"\"\"\n"
"        pass\n"
"\n"
"    def close(self, reason):\n"
"        \"\"\"Called before the spider closes. It may return a deferred."
"\"\"\"\n"
"        pass\n"
"\n"
"    def log(self, request, spider):\n"
"        \"\"\"Logs that a request has been filtered out.\n"
"\n"
"        It is called right after a call to :meth:`request_seen` that\n"
"        returns ``True``.\n"
"\n"
"        If :meth:`request_seen` always returns ``False``, such as in the\n"
"        case of :class:`~scrapy.dupefilters.BaseDupeFilter`, this method\n"
"        may be omitted.\n"
"        \"\"\"\n"
"        pass"
msgstr ""

#: ../../../../scrapy/dupefilters.py:docstring of
#: scrapy.dupefilters.BaseDupeFilter:1
msgid ""
"Dummy duplicate request filtering class (:setting:`DUPEFILTER_CLASS`) that "
"does not filter out any request."
msgstr ""

#: ../../../../scrapy/dupefilters.py:docstring of
#: scrapy.dupefilters.RFPDupeFilter:1
msgid ""
"Duplicate request filtering class (:setting:`DUPEFILTER_CLASS`) that filters "
"out requests with the canonical (:func:`w3lib.url.canonicalize_url`) :attr:"
"`~scrapy.http.Request.url`, :attr:`~scrapy.http.Request.method` and :attr:"
"`~scrapy.http.Request.body`."
msgstr ""

