#: ../../../topics/item-pipeline.rst:63
msgid "Price validation and dropping items with no prices"
msgstr ""

#: ../../../topics/item-pipeline.rst:65
msgid ""
"Let's take a look at the following hypothetical pipeline that adjusts the "
"``price`` attribute for those items that do not include VAT "
"(``price_excludes_vat`` attribute), and drops those items which don't "
"contain a price:"
msgstr ""

#: ../../../topics/item-pipeline.rst:70
msgid ""
"from itemadapter import ItemAdapter\n"
"from scrapy.exceptions import DropItem\n"
"\n"
"\n"
"class PricePipeline:\n"
"    vat_factor = 1.15\n"
"\n"
"    def process_item(self, item):\n"
"        adapter = ItemAdapter(item)\n"
"        if adapter.get(\"price\"):\n"
"            if adapter.get(\"price_excludes_vat\"):\n"
"                adapter[\"price\"] = adapter[\"price\"] * self.vat_factor\n"
"            return item\n"
"        else:\n"
"            raise DropItem(\"Missing price\")"
msgstr ""

#: ../../../topics/item-pipeline.rst:90
msgid "Write items to a JSON lines file"
msgstr ""

#: ../../../topics/item-pipeline.rst:92
msgid ""
"The following pipeline stores all scraped items (from all spiders) into a "
"single ``items.jsonl`` file, containing one item per line serialized in JSON "
"format:"
msgstr ""

#: ../../../topics/item-pipeline.rst:96
msgid ""
"import json\n"
"\n"
"from itemadapter import ItemAdapter\n"
"\n"
"\n"
"class JsonWriterPipeline:\n"
"    def open_spider(self):\n"
"        self.file = open(\"items.jsonl\", \"w\")\n"
"\n"
"    def close_spider(self):\n"
"        self.file.close()\n"
"\n"
"    def process_item(self, item):\n"
"        line = json.dumps(ItemAdapter(item).asdict()) + \"\\n\"\n"
"        self.file.write(line)\n"
"        return item"
msgstr ""

#: ../../../topics/item-pipeline.rst:115
msgid ""
"The purpose of JsonWriterPipeline is just to introduce how to write item "
"pipelines. If you really want to store all scraped items into a JSON file "
"you should use the :ref:`Feed exports <topics-feed-exports>`."
msgstr ""

#: ../../../topics/item-pipeline.rst:120
msgid "Write items to MongoDB"
msgstr ""

#: ../../../topics/item-pipeline.rst:122
msgid ""
"In this example we'll write items to MongoDB_ using pymongo_. MongoDB "
"address and database name are specified in Scrapy settings; MongoDB "
"collection is named after item class."
msgstr ""

#: ../../../topics/item-pipeline.rst:126
msgid ""
"The main point of this example is to show how to :ref:`get the crawler <from-"
"crawler>` and how to clean up the resources properly."
msgstr ""

#: ../../../topics/item-pipeline.rst:130
msgid ""
"import pymongo\n"
"from itemadapter import ItemAdapter\n"
"\n"
"\n"
"class MongoPipeline:\n"
"    collection_name = \"scrapy_items\"\n"
"\n"
"    def __init__(self, mongo_uri, mongo_db):\n"
"        self.mongo_uri = mongo_uri\n"
"        self.mongo_db = mongo_db\n"
"\n"
"    @classmethod\n"
"    def from_crawler(cls, crawler):\n"
"        return cls(\n"
"            mongo_uri=crawler.settings.get(\"MONGO_URI\"),\n"
"            mongo_db=crawler.settings.get(\"MONGO_DATABASE\", \"items\"),\n"
"        )\n"
"\n"
"    def open_spider(self):\n"
"        self.client = pymongo.MongoClient(self.mongo_uri)\n"
"        self.db = self.client[self.mongo_db]\n"
"\n"
"    def close_spider(self):\n"
"        self.client.close()\n"
"\n"
"    def process_item(self, item):\n"
"        self.db[self.collection_name].insert_one(ItemAdapter(item)."
"asdict())\n"
"        return item"
msgstr ""

#: ../../../topics/item-pipeline.rst:168
msgid "Take screenshot of item"
msgstr ""

#: ../../../topics/item-pipeline.rst:170
msgid ""
"This example demonstrates how to use :doc:`coroutine syntax <coroutines>` in "
"the :meth:`process_item` method."
msgstr ""

#: ../../../topics/item-pipeline.rst:173
msgid ""
"This item pipeline makes a request to a locally-running instance of Splash_ "
"to render a screenshot of the item URL. After the request response is "
"downloaded, the item pipeline saves the screenshot to a file and adds the "
"filename to the item."
msgstr ""

#: ../../../topics/item-pipeline.rst:178
msgid ""
"import hashlib\n"
"from pathlib import Path\n"
"from urllib.parse import quote\n"
"\n"
"import scrapy\n"
"from itemadapter import ItemAdapter\n"
"from scrapy.http.request import NO_CALLBACK\n"
"\n"
"\n"
"class ScreenshotPipeline:\n"
"    \"\"\"Pipeline that uses Splash to render screenshot of\n"
"    every Scrapy item.\"\"\"\n"
"\n"
"    SPLASH_URL = \"http://localhost:8050/render.png?url={}\"\n"
"\n"
"    def __init__(self, crawler):\n"
"        self.crawler = crawler\n"
"\n"
"    @classmethod\n"
"    def from_crawler(cls, crawler):\n"
"        return cls(crawler)\n"
"\n"
"    async def process_item(self, item):\n"
"        adapter = ItemAdapter(item)\n"
"        encoded_item_url = quote(adapter[\"url\"])\n"
"        screenshot_url = self.SPLASH_URL.format(encoded_item_url)\n"
"        request = scrapy.Request(screenshot_url, callback=NO_CALLBACK)\n"
"        response = await self.crawler.engine.download_async(request)\n"
"\n"
"        if response.status != 200:\n"
"            # Error happened, return item.\n"
"            return item\n"
"\n"
"        # Save screenshot to file, filename will be hash of url.\n"
"        url = adapter[\"url\"]\n"
"        url_hash = hashlib.md5(url.encode(\"utf8\")).hexdigest()\n"
"        filename = f\"{url_hash}.png\"\n"
"        Path(filename).write_bytes(response.body)\n"
"\n"
"        # Store filename in item.\n"
"        adapter[\"screenshot_filename\"] = filename\n"
"        return item"
msgstr ""

#: ../../../topics/item-pipeline.rst:226
msgid "Duplicates filter"
msgstr ""

#: ../../../topics/item-pipeline.rst:228
msgid ""
"A filter that looks for duplicate items, and drops those items that were "
"already processed. Let's say that our items have a unique id, but our spider "
"returns multiples items with the same id:"
msgstr ""

#: ../../../topics/item-pipeline.rst:232
msgid ""
"from itemadapter import ItemAdapter\n"
"from scrapy.exceptions import DropItem\n"
"\n"
"\n"
"class DuplicatesPipeline:\n"
"    def __init__(self):\n"
"        self.ids_seen = set()\n"
"\n"
"    def process_item(self, item):\n"
"        adapter = ItemAdapter(item)\n"
"        if adapter[\"id\"] in self.ids_seen:\n"
"            raise DropItem(f\"Item ID already seen: {adapter['id']}\")\n"
"        else:\n"
"            self.ids_seen.add(adapter[\"id\"])\n"
"            return item"
msgstr ""

#: ../../../topics/item-pipeline.rst:254
msgid "Activating an Item Pipeline component"
msgstr ""

#: ../../../topics/item-pipeline.rst:256
msgid ""
"To activate an Item Pipeline component you must add its class to the :"
"setting:`ITEM_PIPELINES` setting, like in the following example:"
msgstr ""

#: ../../../topics/item-pipeline.rst:259
msgid ""
"ITEM_PIPELINES = {\n"
"    \"myproject.pipelines.PricePipeline\": 300,\n"
"    \"myproject.pipelines.JsonWriterPipeline\": 800,\n"
"}"
msgstr ""

#: ../../../topics/item-pipeline.rst:266
msgid ""
"The integer values you assign to classes in this setting determine the order "
"in which they run: items go through from lower valued to higher valued "
"classes. It's customary to define these numbers in the 0-1000 range."
msgstr ""

#: ../../../topics/item-pipeline.rst:271
msgid "A complete example"
msgstr ""

#: ../../../topics/item-pipeline.rst:273
msgid ""
"The examples above show item pipeline components on their own. In a project, "
"a pipeline is one of four pieces that work together: the :ref:`item <topics-"
"items>` your spider produces, the :ref:`spider <topics-spiders>` that yields "
"it, the pipeline that processes it, and the :setting:`ITEM_PIPELINES` "
"setting that enables the pipeline."
msgstr ""

#: ../../../topics/item-pipeline.rst:279
msgid ""
"The following example wires those pieces together to validate the price of "
"books scraped from `books.toscrape.com`_, reusing the ``PricePipeline`` "
"from :ref:`price-pipeline-example` above."
msgstr ""

#: ../../../topics/item-pipeline.rst:283
msgid "Define the item in ``myproject/items.py``:"
msgstr ""

#: ../../../topics/item-pipeline.rst:285
msgid ""
"from dataclasses import dataclass\n"
"\n"
"\n"
"@dataclass\n"
"class BookItem:\n"
"    title: str\n"
"    price: float"
msgstr ""

#: ../../../topics/item-pipeline.rst:295
msgid ""
"Yield instances of that item from your spider, e.g. in ``myproject/spiders/"
"books.py``:"
msgstr ""

#: ../../../topics/item-pipeline.rst:299
msgid ""
"import scrapy\n"
"\n"
"from myproject.items import BookItem\n"
"\n"
"\n"
"class BooksSpider(scrapy.Spider):\n"
"    name = \"books\"\n"
"    start_urls = [\"https://books.toscrape.com/\"]\n"
"\n"
"    def parse(self, response):\n"
"        for book in response.css(\"article.product_pod\"):\n"
"            yield BookItem(\n"
"                title=book.css(\"h3 a::attr(title)\").get(),\n"
"                price=float(book.css(\"p.price_color::text\")."
"re_first(r\"[\\d.]+\")),\n"
"            )"
msgstr ""

#: ../../../topics/item-pipeline.rst:317
msgid ""
"Put the ``PricePipeline`` shown earlier in ``myproject/pipelines.py``, and "
"enable it in ``myproject/settings.py``:"
msgstr ""

#: ../../../topics/item-pipeline.rst:320
msgid ""
"ITEM_PIPELINES = {\n"
"    \"myproject.pipelines.PricePipeline\": 300,\n"
"}"
msgstr ""

#: ../../../topics/item-pipeline.rst:326
msgid ""
"With these pieces in place, every ``BookItem`` that ``BooksSpider`` yields "
"passes through ``PricePipeline`` before it reaches the :ref:`feed exports "
"<topics-feed-exports>` or any other output."
msgstr ""

#: ../../../topics/item-pipeline.rst:334
msgid "Common pitfalls"
msgstr ""

#: ../../../topics/item-pipeline.rst:337
msgid "The pipeline does not run"
msgstr ""

#: ../../../topics/item-pipeline.rst:339
msgid ""
"A pipeline component only runs if its class is listed in the :setting:"
"`ITEM_PIPELINES` setting, normally in your project's :file:`settings.py` "
"file (see :ref:`activating-item-pipeline`). Adding it to the spider or "
"elsewhere has no effect."
msgstr ""

#: ../../../topics/item-pipeline.rst:344
msgid ""
"To confirm that Scrapy loaded your pipeline, look for a line like this near "
"the start of the crawl log::"
msgstr ""

#: ../../../topics/item-pipeline.rst:347
msgid ""
"[scrapy.middleware] INFO: Enabled item pipelines:\n"
"['myproject.pipelines.PricePipeline']"
msgstr ""

#: ../../../topics/item-pipeline.rst:350
msgid ""
"If your pipeline is missing from that list, check that its import path "
"matches the :setting:`ITEM_PIPELINES` entry, and that the setting is not "
"being overridden, for example by :attr:`~scrapy.Spider.custom_settings` or "
"by a redefinition of :setting:`ITEM_PIPELINES` in :file:`settings.py`."
msgstr ""

#: ../../../topics/item-pipeline.rst:356
msgid "The item is not returned"
msgstr ""

#: ../../../topics/item-pipeline.rst:358
msgid ""
":meth:`process_item` must return the item (or raise :exc:`~scrapy.exceptions."
"DropItem`). A common mistake is to modify the item but forget to return it:"
msgstr ""

#: ../../../topics/item-pipeline.rst:362
msgid ""
"def process_item(self, item):\n"
"    ItemAdapter(item)[\"price\"] *= 1.15\n"
"    # Bug: returns None, so the next component gets None instead of the item."
msgstr ""

#: ../../../topics/item-pipeline.rst:368
msgid ""
"Return the item so that the next component, and the rest of Scrapy, can keep "
"processing it:"
msgstr ""

#: ../../../topics/item-pipeline.rst:371
msgid ""
"def process_item(self, item):\n"
"    ItemAdapter(item)[\"price\"] *= 1.15\n"
"    return item"
msgstr ""
