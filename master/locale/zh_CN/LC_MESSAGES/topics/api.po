#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.getdict:1
msgid ""
"Get a setting value as a dictionary. If the setting original type is a "
"dictionary, a copy of it will be returned. If it is a string it will be "
"evaluated as a JSON dictionary. In the case that it is a :class:`~scrapy."
"settings.BaseSettings` instance itself, it will be converted to a "
"dictionary, containing all its current settings values as they would be "
"returned by :meth:`~scrapy.settings.BaseSettings.get`, and losing all "
"information about priority and mutability."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.getdictorlist:1
msgid "Get a setting value as either a :class:`dict` or a :class:`list`."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.getdictorlist:3
msgid ""
"If the setting is already a dict or a list, a copy of it will be returned."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.getdictorlist:6
msgid ""
"If it is a string it will be evaluated as JSON, or as a comma-separated list "
"of strings as a fallback."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.getdictorlist:9
msgid "For example, settings populated from the command line will return:"
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.getdictorlist:11
msgid ""
"``{'key1': 'value1', 'key2': 'value2'}`` if set to ``'{\"key1\": \"value1\", "
"\"key2\": \"value2\"}'``"
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.getdictorlist:14
msgid "``['one', 'two']`` if set to ``'[\"one\", \"two\"]'`` or ``'one,two'``"
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.getfloat:1
msgid "Get a setting value as a float."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.getint:1
msgid "Get a setting value as an int."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.getlist:1
msgid ""
"Get a setting value as a list. If the setting original type is a list, a "
"copy of it will be returned. If it's a string it will be split by \",\". If "
"it is an empty string, an empty list will be returned."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.getlist:5
msgid ""
"For example, settings populated through environment variables set to ``'one,"
"two'`` will return a list ['one', 'two'] when using this method."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
