#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.replace_in_component_priority_dict:1
msgid ""
"Replace *old_cls* with *new_cls* in the *name* :ref:`component priority "
"dictionary <component-priority-dictionaries>`."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.replace_in_component_priority_dict:4
msgid ""
"If *old_cls* is missing, or has :data:`None` as value, :exc:`KeyError` is "
"raised."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.replace_in_component_priority_dict:7
msgid ""
"If *old_cls* was present as an import string, even more than once, those "
"keys are dropped and replaced by *new_cls*."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.replace_in_component_priority_dict:10
msgid ""
"If *priority* is specified, that is the value assigned to *new_cls* in the "
"component priority dictionary. Otherwise, the value of *old_cls* is used. If "
"*old_cls* was present multiple times (possible with import strings) with "
"different values, the value assigned to *new_cls* is one of them, with no "
"guarantee about which one it is."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.set:1
msgid "Store a key/value attribute with a given priority."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.set:3
msgid ""
"Settings should be populated *before* configuring the Crawler object "
"(through the :meth:`~scrapy.crawler.Crawler.configure` method), otherwise "
"they won't have any effect."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.set:10
msgid "the value to associate with the setting"
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.set:13
msgid ""
"the priority of the setting. Should be a key of :attr:`~scrapy.settings."
"SETTINGS_PRIORITIES` or an integer"
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.set_in_component_priority_dict:1
msgid ""
"Set the *cls* component in the *name* :ref:`component priority dictionary "
"<component-priority-dictionaries>` setting with *priority*."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.set_in_component_priority_dict:4
msgid "If *cls* already exists, its value is updated."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.set_in_component_priority_dict:6
msgid ""
"If *cls* was present as an import string, even more than once, those keys "
"are dropped and replaced by *cls*."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.setdefault_in_component_priority_dict:1
msgid ""
"Set the *cls* component in the *name* :ref:`component priority dictionary "
"<component-priority-dictionaries>` setting with *priority* if not already "
"defined (even as an import string)."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.setdefault_in_component_priority_dict:5
msgid ""
"If *cls* is not already defined, it is set regardless of the priority of the "
"*name* setting. The setting priority is not affected by this change either."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.setmodule:1
msgid "Store settings from a module with a given priority."
msgstr ""

#: ../../../../scrapy/settings/__init__.py:docstring of
#: scrapy.settings.BaseSettings.setmodule:3
