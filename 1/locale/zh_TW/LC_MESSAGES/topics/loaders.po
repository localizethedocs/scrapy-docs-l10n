"# HTML snippet: <p id=\"price\">the price is $1200</p>\n"
"loader.get_css('p#price', TakeFirst(), re='the price is (.*)')"
msgstr ""

#: ../../../topics/loaders.rst:428
msgid ""
"Similar to :meth:`ItemLoader.add_value` but receives a CSS selector instead "
"of a value, which is used to extract a list of unicode strings from the "
"selector associated with this :class:`ItemLoader`."
msgstr ""

#: ../../../topics/loaders.rst:432
msgid "See :meth:`get_css` for ``kwargs``."
msgstr ""

#: ../../../topics/loaders.rst:439
msgid ""
"# HTML snippet: <p class=\"product-name\">Color TV</p>\n"
"loader.add_css('name', 'p.product-name')\n"
"# HTML snippet: <p id=\"price\">the price is $1200</p>\n"
"loader.add_css('price', 'p#price', re='the price is (.*)')"
